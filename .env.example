# Copy to .env and fill in. Never commit the real .env.
LEE3D_DATA_DIR=./data
LEE3D_GITHUB_OWNER=BEARME-A
LEE3D_LIB_REPO=LEE3D-Lib
LEE3D_LIB_BRANCH=main
# Fine-grained PAT with Contents: read & write on LEE3D-Lib only.
LEE3D_GITHUB_TOKEN=
# Allowed frontend origins (comma separated).
LEE3D_CORS_ORIGINS=http://localhost:3000,https://bearme-a.github.io
